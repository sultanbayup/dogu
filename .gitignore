# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
.output/

# ── Vite ──────────────────────────────────────────────────────────────────────
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Test & coverage ───────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output

# ── Playwright ────────────────────────────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
blob-report/

# ── Bundle visualizer (build artifact, regenerated on every build) ────────────
stats.html

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime / OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pid
*.seed
*.pid.lock

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Kiro (local AI dev tool — contains personal data, never commit) ───────────
.kiro/

